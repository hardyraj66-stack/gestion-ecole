# Copier en `server/.env` et renseigner. Ce fichier d'exemple est versionné ; `.env` ne l'est PAS.

# --- Serveur / base de données ---
# PORT=3000
# MONGO_URI=mongodb://localhost:27017/gestion-ecole

# --- Authentification ---
# Secret de signature des JWT (OBLIGATOIRE en production : le serveur refuse de
# démarrer si NODE_ENV=production et JWT_SECRET absent)
# JWT_SECRET=change-me-en-production
# Compte admin créé au premier démarrage si aucun utilisateur n'existe
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123

# URL du frontend (pour les liens email, ex. réinitialisation de mot de passe)
APP_URL=http://localhost:5173
# Origines CORS autorisées (séparées par des virgules). Vide = ouvert (dev only).
# CORS_ORIGIN=http://localhost:5173,https://ekolova.example.com

# --- SMTP (envoi des identifiants professeur) ---
# Si SMTP_HOST est vide, l'envoi est désactivé sans erreur : le mot de passe
# généré est alors renvoyé à l'admin pour transmission manuelle.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Ekolova <no-reply@ekolova.local>"
