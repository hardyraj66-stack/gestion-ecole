# Variables lues par docker-compose (racine). Copier en `.env` et renseigner.
# Ce fichier d'exemple est versionné ; `.env` ne l'est PAS (secrets).

# --- Caddy / domaine ---
# Domaine du site → HTTPS Let's Encrypt automatique (ex. ekolova.duckdns.org),
# ou ":80" pour servir en HTTP simple en local.
SITE_ADDRESS=ekolova.duckdns.org
# Email de contact pour Let's Encrypt (avis d'expiration / problème de certificat).
# Laisser vide en HTTP simple local ; requis pour la délivrance ACME en prod.
ACME_EMAIL=admin@example.com

# --- MongoDB (authentification activée) ---
# Hôte/port = nom du service Docker (réseau interne), pas exposé hors des conteneurs.
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=gestion-ecole
# Base où sont définis les utilisateurs (→ authSource dans l'URI).
MONGO_AUTH_SOURCE=admin
# Compte root (maintenance / init d'un volume vierge). Mot de passe fort obligatoire.
MONGO_ROOT_USER=ekolova_root
MONGO_ROOT_PASSWORD=change-me-strong
# Compte applicatif à privilèges limités (readWrite+dbAdmin sur MONGO_DB uniquement) :
# c'est celui qu'utilise l'API. L'URI est assemblée dans docker-compose.yml.
MONGO_USER=ekolova_app
MONGO_PASSWORD=change-me-strong
